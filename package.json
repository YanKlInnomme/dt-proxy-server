{
  "name": "dt-proxy-server",
  "version": "1.0.0",
  "description": "Local proxy server for the Deep Translate Foundry VTT module. Handles DeepL API requests, batch translation, and session-based caching while keeping API keys on the client side.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "pkg .",
    "test": "echo \"No tests defined\" && exit 0"
  },
  "keywords": [
    "deepl",
    "translation",
    "proxy",
    "foundryvtt",
    "foundry-vtt",
    "deep-translate",
    "ttrpg",
    "api-proxy"
  ],
  "author": "YanK <contact@yanklinnomme.fr> (https://yanklinnomme.fr)",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "deepl-node": "^1.26.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "bin": "server.js",
  "pkg": {
    "targets": [
      "node18-win-x64",
      "node18-linux-x64"
    ],
    "outputPath": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YanKlInnomme/dt-proxy-server"
  },
  "bugs": {
    "url": "https://github.com/YanKlInnomme/dt-proxy-server/issues"
  },
  "homepage": "https://yanklinnomme.fr"
}
